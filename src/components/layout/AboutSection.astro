---
// import ImageWrapper from "@/ui/ImageWrapper.astro";
import InfoBanner from "@/ui/InfoBanner.astro";
import SocialLink from "@/components/SocialLink.astro";
import Button from "../ui/Button.astro";
import { SOCIAL_LINK, type HTML } from "@/scripts/constants";

interface Props extends HTML {
	photo?: boolean;
}

const { photo, class: className } = Astro.props;
---

{
	photo ? (
		<div
			class:list={["relative flex flex-col w-[320px] h-[320px]", className]}
			style={{ "--radius": "32px" }}
		>
			{/* <ImageWrapper alt="About photo" size="md" shape="round" aspect="1/1" src="/about/about.png" /> */}
			<div class="absolute top-2 -rotate-4">
				<InfoBanner />
			</div>
			<p class="absolute card-sm bottom-2 rotate-2">
				I'm Jay, and I make roller coasters out of polygons!
			</p>
			<SocialLink
				icon={SOCIAL_LINK.gumroad.icon}
				href={SOCIAL_LINK.gumroad.href}
				rotation="105"
			/>
			<SocialLink
				icon={SOCIAL_LINK.sketchfab.icon}
				href={SOCIAL_LINK.sketchfab.href}
				rotation="125"
			/>
			<SocialLink
				title={SOCIAL_LINK.youtube.title}
				icon={SOCIAL_LINK.youtube.icon}
				href={SOCIAL_LINK.youtube.href}
				rotation="145"
			/>
			<SocialLink
				icon={SOCIAL_LINK.bluesky.icon}
				href={SOCIAL_LINK.bluesky.href}
				rotation="165"
			/>
		</div>
	) : (
		<aside class={`column-sm card ${className}`}>
			{/* <p class="">My name is Jay, and I make roller coasters out of polygons!</p> */}
			<InfoBanner style="error"/>
			<div class="row-sm">
				<Button icon={SOCIAL_LINK.gumroad.icon} href={SOCIAL_LINK.gumroad.href} iconOnly />
				<Button icon={SOCIAL_LINK.sketchfab.icon} href={SOCIAL_LINK.sketchfab.href} iconOnly />
				<Button icon={SOCIAL_LINK.youtube.icon} href={SOCIAL_LINK.youtube.href} iconOnly />
				<Button icon={SOCIAL_LINK.bluesky.icon} href={SOCIAL_LINK.bluesky.href} iconOnly />
				<Button icon={SOCIAL_LINK.email.icon} href={SOCIAL_LINK.email.href} iconOnly />
			</div>
		</aside>
	)
}
