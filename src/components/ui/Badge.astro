---
import Icon, { type ICON_NAME } from '@/ui/Icon.astro';

interface Props {
	label: string;
	style?: "primary" | "alt" | "default"
	icon?: ICON_NAME;
	iconRight?: boolean;
}

const {
	label,
	style = "default",
	icon = false,
	iconRight = false
} = Astro.props;

function setBackgroundColor (badgeStyle: typeof style): string {
	if (badgeStyle === "primary") {
		return "--badge-bg: var(--brand-bg); --outline: var(--brand-outline);";
	} else if (badgeStyle === "alt") {
		return "--badge-bg: var(--alt-bg-light); --text: var(--alt-text);";
	}

	return "--badge-bg: var(--bg-light)";
}
---

<strong
	style={setBackgroundColor(style)}
	class="badge row-xs center border"
>

	{icon && !iconRight && <Icon name={icon} size="16" strokeWidth="4" />}
	<small>{label}</small>
	{icon && iconRight && <Icon name={icon} size="16" strokeWidth="4" />}
</strong>

<style>
	.badge {
		max-width: fit-content;
		padding-block: var(--space-1);
		padding-inline: var(--space-3);

		border-color: var(--outline);
		border-radius: var(--radius-pill);
		background: var(--badge-bg);

		small {
			line-height: var(--space-3);
			text-wrap: nowrap;
		}
	}
</style>
