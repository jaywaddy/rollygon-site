---
import Badge from './Badge.astro';

interface Props{
    heading: string;
    headingSize: "h1" | "h2" | "h3";
    subHeading?: string;
    badgeLabel?: string | null;
    badgeStyle?: "primary" | "alt" | "default";
}

const { heading, headingSize, subHeading, badgeLabel = null, badgeStyle = "default" } = Astro.props;
---
<div class="section-title">
    {badgeLabel && <Badge label={badgeLabel} style={badgeStyle}/>}
    {headingSize === "h1" && <h1>{heading}</h1>}
    {headingSize === "h2" && <h2>{heading}</h2>}
    {headingSize === "h3" && <h3>{heading}</h3>}
    {subHeading && <p data-subheading>{subHeading}</p>}
</div>

<style>
    .section-title {
        display: flex;
        flex-direction: column;
        gap: var(--space-2);

        p {
            color: var(--text-muted);
        }
    }
</style>