---
import ContentNavigation from "@/components/ContentNavigation.astro";
import AssetPoster from "@/components/ui/AssetPoster.astro";
import SideBar from "@/components/SideBar.astro";

import { calcReadTime, formatDate, setImageSrc } from "@/scripts/utilities";
import type { Collection } from "@/content/config";
import Button from "@/components/ui/Button.astro";
import TableOfContents from "@/components/ui/TableOfContents.astro";

interface Props {
	content: Collection;
	contentCollection: Array<Collection>;
	index: number;
}

const { content, contentCollection, index } = Astro.props;
const { title, description, postDate, tags, lastUpdated } = content.data;
const { collection, body } = content;
const { headings } = await content.render();

function setButtonLabel(): string {
	if (collection === "tools" && content.data.price === "$0+") {
		return "Download"
	}

	return "Buy";
}
---

<div class="column-lg">
	{
		content.collection === "models" ? (
			<div class="column-md">
				<ContentNavigation {content} {contentCollection} {index} />
				<AssetPoster {title} modelID={content.data.id} />
			</div>
		) : (
			<div class="relative column-md">
				<ContentNavigation {content} {contentCollection} {index} />
				{content.collection === "posts" && content.data.embed ? (
					<AssetPoster title={title} videoEmbed={content.data.embed} />
				) : (
					<AssetPoster title={title} src={setImageSrc(content)} />
				)}
			</div>
		)
	}
	<div class="row-lg">
		<section class="column-lg">
			<div class="column-md">
				<h1>{title}</h1>
				<p>{description}</p>
				<div class="column-md">
					{
						collection === "posts" && (
							<small>
								<strong>{formatDate(postDate)}</strong>
								<span>&bullet;</span>
								<strong>{calcReadTime(body)} min read</strong>
							</small>
						)
					}
					{
						collection === "posts" && content.data.postUpdate && (
							<small>
								<em>Updated:</em>
								<em>{formatDate(content.data.postUpdate)}</em>
							</small>
						)
					}
					{
						collection === "tools" && (
							<small>
								<strong>{formatDate(postDate)}</strong>
								<span>&bullet;</span>
								<strong>{content.data.version}</strong>
							</small>
							<Button label={`${setButtonLabel()} tool`} icon="download" href={content.data.href} primary />
						)
					}
					{
						collection === "models" && (
							<small>
								<strong>{formatDate(postDate)}</strong>
								<span>&bullet;</span>
								<strong>{content.data.size}</strong>
							</small>
						)
					}
					{
						lastUpdated && <small>Last updated: {formatDate(lastUpdated)}</small>
					}
				</div>
			</div>
			{ headings.length > 0 && <TableOfContents class:list={["hidden", "max-sm:flex"]} {headings} /> }
			<article class="content column-md">
				<slot />
			</article>
		</section>
		<SideBar class="max-sm:hidden" {headings} {content} />
	</div>
</div>
