---
import PageTitle from "@/components/layout/PageTitle.astro";
import SiteLayout from "@/layouts/SiteLayout.astro";
import * as aboutContent from "./about.md";
import { Content } from "./about.md";
import Button from "@/components/ui/Button.astro";
import { formatDate } from "@/scripts/utilities";
import { SOCIAL_LINK } from "@/scripts/constants";

const { title, date } = aboutContent.frontmatter;
const { gumroad, sketchfab, youtube, email } = SOCIAL_LINK;
---

<SiteLayout pageTitle={title}>
	<PageTitle heading={title} />
	<div class="column-md">
		<div class="about-section card column-md">
			<p>
				My name is Jay and I make roller coasters out of
				polygons. I also build tools that make coaster manufacturer specific tracks,
				supports, etc. that help me create realistic coaster models.
			</p>
			<span>Social links:</span>
			<div class="row-sm">
				<Button
					label={gumroad.title}
					icon={gumroad.icon}
					href={gumroad.href}
				/>
				<Button
					label={sketchfab.title}
					icon={sketchfab.icon}
					href={sketchfab.href}
				/>
				<Button
					label={youtube.title}
					icon={youtube.icon}
					href={youtube.href}
				/>
				<Button
					label={email.title}
					icon={email.icon}
					href={email.href}
				/>
			</div>
		</div>
		<small>Last update: {formatDate(date)}</small>
		<article class="content column-md">
			<Content />
		</article>
	</div>
</SiteLayout>

<style>
	.about-section {
		width: var(--content-width);
	}
</style>
